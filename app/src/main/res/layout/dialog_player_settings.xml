<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="300dp"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#CC000000"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Player Settings"
        android:textColor="#FFFFFF"
        android:textSize="20sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp"/>

    <TextView
        android:id="@+id/btn_audio_tracks"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Audio Tracks"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="?android:attr/selectableItemBackground"
        android:focusable="true"
        android:clickable="true"/>

    <TextView
        android:id="@+id/btn_software_decoding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Use Software Decoding"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="?android:attr/selectableItemBackground"
        android:focusable="true"
        android:clickable="true"/>

    <TextView
        android:id="@+id/btn_hardware_decoding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Use Hardware Decoding"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="?android:attr/selectableItemBackground"
        android:focusable="true"
        android:clickable="true"/>

    <TextView
        android:id="@+id/btn_alternative_audio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Alternative Audio Config"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="?android:attr/selectableItemBackground"
        android:focusable="true"
        android:clickable="true"/>

    <TextView
        android:id="@+id/btn_reset_player"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Reset Player"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        android:padding="12dp"
        android:background="?android:attr/selectableItemBackground"
        android:focusable="true"
        android:clickable="true"/>
</LinearLayout> 