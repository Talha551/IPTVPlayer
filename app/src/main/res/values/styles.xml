<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="PlayerViewStyle">
        <item name="android:background">@android:color/black</item>
        <item name="surface_type">surface_view</item>
        <item name="use_controller">false</item>
        <item name="show_timeout">0</item>
        <item name="hide_on_touch">true</item>
        <item name="auto_show">false</item>
    </style>

    <style name="Theme.TV247IPTVPlayer" parent="@style/Theme.Leanback">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLayoutInDisplayCutoutMode">shortEdges</item>
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowTranslucentNavigation">true</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="defaultBrandColor">@color/fastlane_background</item>
        <item name="defaultSearchColor">@color/search_opaque</item>
    </style>

    <style name="AlertDialogTheme" parent="ThemeOverlay.AppCompat.Dialog.Alert">
        <item name="android:background">@android:color/white</item>
        <item name="android:textColorPrimary">@android:color/black</item>
        <item name="android:windowBackground">@android:color/transparent</item>
    </style>
</resources> 